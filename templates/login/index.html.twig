{% extends 'base.html.twig' %}

{% block title %}Login!{% endblock %}

{% block body %}

<div class="container my-5">
    <h1>Connexion</h1>
  {% if error %}
        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form action="{{ path('app_login') }}" method="post">
        <label class="mt-4" for="username">Votre email:</label>
        <input class="form-control" type="text" id="username" name="_username" value="{{ last_username }}" required>

        <label class="mt-2" for="password">Votre mot de passe:</label>
        <input class="form-control" type="password" id="password" name="_password" required>
      
        <input type="hidden" name="_target_path" value="{{ path('app_account') }}">

        <button class="btn btn-primary mt-5" type="submit">Me connecter</button>
        <p class="mt-3">
            Vous n'avez pas de compte ? <a href="{{ path('app_register') }}">Inscrivez-vous</a>
        </p>
    </form>
</div>
{% endblock %}
