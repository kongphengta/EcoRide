<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Covoiturage</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-primary">
            <div class="container">
                <a class="navbar-brand text-white" href="{{ asset('/') }}">
                    <img src="{{ asset('assets/images/logo.png') }}" alt="Logo" width="59" height="59" class="d-inline-block align-text-top"><br>
                    EcoRide Covoiturage
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link active text-white" aria-current="page" href="{{ asset('/') }}">Accueil</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="{{ path('app_register') }}">Créer un compte</a>
                            </li>              
                            <li class="nav-item">
                                <a class="nav-link text-white" href="{{ path('app_login') }}">Se connecter</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="#">À propos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white me-5" href="#">Contact</a>
                            </li>
                        </ul>
                
                        <div class="speed-menu">
                            {% if app.user %}
                            <a class="text-white" style="text-decoration: none" href="{{ path('app_account') }}"><i class="fa-solid fa-user me-3"></i>{{ app.user.prenom }}</a>
                            {% else %}
                            <a href="{{ path('app_login') }}"><i class="fa-solid fa-user me-3"></i></a>
                            {% endif %}
                        </div>
                </div>
            </div>
        </nav>
               
    </header>

    <main>

        <div class="container text-center my-5">        
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {% block body %}
        {% endblock %}
    </main>

    <footer class="bg-light text-center py-3 ">
        <p>Contactez-nous : <a href="mailto:contact@covoiturage.com">contact@covoiturage.com</a></p>
        <p><a href="/mentions-legales">Mentions légales</a></p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js" integrity="sha384-0pUGZvbkm6XF6gxjEnlmuGrJXVbNuzT9qBBavbLwCsOGabYfZo0T0to5eqruptLy" crossorigin="anonymous"></script>
    <script src="{{ asset('assets/js/script.js') }}"></script>
</body>
</html>

